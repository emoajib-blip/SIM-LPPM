APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=sim_lppm
DB_USERNAME=postgres
DB_PASSWORD=

# Installer Configuration
INSTALLER_ENABLED=true
INSTALLER_AUTO_INIT=false

# Initial Admin Configuration (Used by AdminUserSeeder)
SUPERADMIN_NAME="Super Administrator"
SUPERADMIN_EMAIL=superadmin@email.com
ADMIN_LPPM_NAME="Admin LPPM"
ADMIN_LPPM_EMAIL=admin-lppm@email.com
REKTOR_NAME="Ali Imron"
REKTOR_EMAIL=rektor@email.com
INITIAL_ADMIN_PASSWORD=password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
MEDIA_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Document Signature Configuration
DOCUMENT_SIGNATURE_KID=v1
DOCUMENT_SIGNATURE_SECRET=your-secret-key-here

# Sync Configuration (Local → Production pull)
SYNC_SSH_HOST=
SYNC_SSH_USER=
SYNC_SSH_PORT=22
SYNC_SSH_KEY_PATH=
SYNC_REMOTE_HOST=
SYNC_REMOTE_USER=
SYNC_REMOTE_PATH=/home/user/project
SYNC_REMOTE_DB=
SYNC_REMOTE_DB_USER=
SYNC_REMOTE_DB_PASSWORD=
SYNC_REMOTE_DB_CONNECTION=mysql
