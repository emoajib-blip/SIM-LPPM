# =============================================================================
# SIM LPPM ITSNU - PRODUCTION ENVIRONMENT TEMPLATE (Google Cloud Run)
# =============================================================================
# Gunakan file ini sebagai acuan saat mengisi 'Environment Variables'
# di Dashboard Google Cloud Run. 

APP_NAME="SIM LPPM ITSNU"
APP_ENV=production
APP_KEY=base64:wR54BxUsOi/ILFPFYSFic+0/ttVExD8jY/wQiQg4R4w=
APP_DEBUG=false
APP_URL=https://sim-lppm.itsnupekalongan.ac.id

LOG_CHANNEL=stack
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# DATABASE: Google Cloud SQL (MySQL)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
# Gunakan DB_SOCKET jika mendeploy di Google Cloud Run (Cara Termudah)
DB_SOCKET="/cloudsql/[CONNECTION_NAME_PROYEK_ANDA]"
DB_DATABASE=sim_lppm
DB_USERNAME=root
DB_PASSWORD=[PASSWORD_DATABASE_ANDA]

# -----------------------------------------------------------------------------
# BROADCAST & CACHE (Production settings)
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# FILESYSTEM (Gunakan disk internal Cloud Run atau Cloud Storage)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=public
