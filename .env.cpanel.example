# =============================================================================
# SIM LPPM ITSNU - CPANEL PRODUCTION ENVIRONMENT TEMPLATE
# =============================================================================

APP_NAME="SIM LPPM ITSNU"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=error

# -----------------------------------------------------------------------------
# DATABASE: Standard MySQL (cPanel)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# -----------------------------------------------------------------------------
# BROADCAST & CACHE (Production settings)
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
SESSION_LIFETIME=120

# -----------------------------------------------------------------------------
# FILESYSTEM & MAIL
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=public

MAIL_MAILER=smtp
MAIL_HOST=mail.setup.com
MAIL_PORT=465
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@itsnu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"
